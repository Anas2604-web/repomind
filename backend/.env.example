# Copy this file to .env and fill in your real key.
# Get a free Groq key at https://console.groq.com/keys

GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Leave these as defaults unless you have a reason to change them
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
QDRANT_STORAGE_PATH=./qdrant_data
CLONE_DIR=./cloned_repos
REGISTRY_DB_PATH=./repomind.db

# Clerk — Dashboard -> API Keys -> "Show JWT public key" -> PEM Public Key.
# Paste with \n for line breaks (this code unescapes them). Leave blank to
# skip auth entirely in local dev (everyone treated as "anonymous").
CLERK_JWT_KEY=
